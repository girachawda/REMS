<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Invoices</h1>
    <p class="text-muted mb-0">View rent, utility, and maintenance invoices.</p>
  </div>
</div>

<% if @invoices.any? %>
  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Tenant</th>
              <th>Property</th>
              <th>Unit</th>
              <th>Charge Type</th>
              <th>Total Charge</th>
              <th>Due Date</th>
              <th>Status</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% @invoices.each do |invoice| %>
              <% tenant = invoice.lease.user %>
              <% unit = invoice.lease.unit %>
              <% property = unit.property %>

              <% badge_classes = case invoice.status
                 when "paid" then "bg-success"
                 when "unpaid" then "bg-warning text-dark"
                 when "overdue" then "bg-danger"
                 else "bg-secondary"
                 end %>

              <tr>
                <td>
                  <div class="fw-semibold"><%= tenant.name %></div>
                  <small class="text-muted"><%= tenant.email %></small>
                </td>

                <td>
                  <%= property.name %>
                </td>

                <td>
                  <strong>Unit <%= unit.unit_number %></strong>
                </td>

                <td>
                  <span class="text-capitalize"><%= invoice.charge_type %></span>
                </td>

                <td>
                  $<%= sprintf("%.2f", invoice.total_charge.to_f) %>
                </td>

                <td>
                  <%= invoice.due_date.strftime("%b %d, %Y") %>
                </td>

                <td>
                  <span class="badge <%= badge_classes %> text-capitalize">
                    <%= invoice.status %>
                  </span>
                </td>

                <td class="text-end">
                  <%= link_to "View",
                      invoice_path(invoice),
                      class: "btn btn-sm btn-outline-primary" %>
                </td>
              </tr>
            <% end %>
          </tbody>

        </table>
      </div>
    </div>
  </div>
<% else %>
  <div class="card shadow-sm border-0">
    <div class="card-body text-center py-5">
      <h4 class="text-muted mb-3">No invoices found</h4>
      <p class="text-muted mb-0">Invoices will appear here once they are generated.</p>
    </div>
  </div>
<% end %>