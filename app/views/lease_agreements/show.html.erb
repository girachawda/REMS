<div class="container mt-5">
  <div class="card shadow-sm p-4">

    <h2 class="text-center mb-4">Lease Agreement</h2>

    <hr>

    <p><strong>Tenant:</strong> <%= @lease_agreement.user.name %></p>
    <p><strong>Property:</strong> <%= @lease_agreement.unit.property.name %></p>
    <p><strong>Unit:</strong> <%= @lease_agreement.unit.unit_number %></p>

    <hr>

    <p>
      This Lease Agreement is made between
      <strong><%= @lease_agreement.user.name %></strong>
      (the "Tenant") and the Property Owner.
    </p>

    <p>
      The Tenant agrees to lease Unit
      <strong><%= @lease_agreement.unit.unit_number %></strong>
      located at
      <strong><%= @lease_agreement.unit.property.address %></strong>.
    </p>

    <hr>

    <h5>Lease Terms</h5>

    <ul>
      <li><strong>Start Date:</strong> <%= @lease_agreement.start_date %></li>
      <li><strong>End Date:</strong> <%= @lease_agreement.end_date %></li>
      <li><strong>Duration:</strong> <%= @lease_agreement.duration %> months</li>
      <li><strong>Monthly Rent:</strong> $<%= @lease_agreement.unit.rental_rate %></li>
    </ul>

    <hr>

    <p>
      The Tenant agrees to pay the monthly rent on time and abide by all
      property rules and regulations.
    </p>

    <p>
      Failure to comply may result in termination of this lease agreement.
    </p>

    <hr>

    <div class="row mt-5 text-center">

      <div class="col">
        <% if current_user.leasing_agent? %>
          <% if @lease_agreement.tenant_signed %>
            <p>Signed by Tenant</p>
          <% else %>
            <p>Awaiting Tenant Signature</p>
          <% end %>
        <% else %>
          <% if @lease_agreement.tenant_signed %>
            <p>Signed by Tenant</p>
          <% else %>
            <%= button_to "Sign as Tenant",
                sign_tenant_lease_agreement_path(@lease_agreement),
                method: :patch,
                class: "btn btn-primary" %>
          <% end %>
        <% end %>
        
      </div>

      <div class="col">
        <% if current_user.leasing_agent? %>
          <% if @lease_agreement.agent_signed %>
            <p>Signed by Agent</p>
          <% else %>
            <%= button_to "Sign as Agent",
                sign_agent_lease_agreement_path(@lease_agreement),
                method: :patch,
                class: "btn btn-success" %>
          <% end %>
        <% else %>
          <% if @lease_agreement.agent_signed %>
            <p>Signed by Agent</p>
          <% else %>
            <p>Awaiting Agent Signature</p>
          <% end %>
        <% end %>
      </div>

    </div>

  </div>
</div>
