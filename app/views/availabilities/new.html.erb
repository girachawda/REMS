<h1>Add Availability</h1>

<%= form_with model: @availability, url: availabilities_path do |form| %>
  <% if @availability.errors.any? %>
    <div style="color: red;">
      <h3><%= pluralize(@availability.errors.count, "error") %> prevented this availability from being saved:</h3>
      <ul>
        <% @availability.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :property_id, "Property" %>
    <%= form.collection_select :property_id, @properties, :id, :name, { prompt: "Select a property" } %>
  </div>

  <div>
    <%= form.label :start_time, "Start Time" %>
    <%= form.datetime_field :start_time, required: true %>
  </div>

  <div>
    <%= form.label :end_time, "End Time" %>
    <%= form.datetime_field :end_time, required: true %>
  </div>

  <div>
    <%= form.submit "Create Availability" %>
  </div>
<% end %>

<%= link_to "Back", availabilities_path %>
