<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">

      <div class="card shadow-sm border-0">
        <div class="card-body p-4">

          <h3 class="card-title mb-4 text-center">Add Availability</h3>

          <%= form_with model: @availability, url: availabilities_path do |form| %>

            <% if @availability.errors.any? %>
              <div class="alert alert-danger">
                <h5 class="mb-2">
                  <%= pluralize(@availability.errors.count, "error") %> prevented this availability from being saved:
                </h5>
                <ul class="mb-0">
                  <% @availability.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :property_id, "Property", class: "form-label" %>
              <%= form.collection_select :property_id,
                  @properties,
                  :id,
                  :name,
                  { prompt: "Select a property" },
                  class: "form-select" %>
            </div>

            <div class="mb-3">
              <%= form.label :start_time, "Start Time", class: "form-label" %>
              <%= form.datetime_field :start_time, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :end_time, "End Time", class: "form-label" %>
              <%= form.datetime_field :end_time, class: "form-control", required: true %>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
              <%= link_to "Back", availabilities_path, class: "btn btn-secondary" %>
              <%= form.submit "Create Availability", class: "btn btn-primary" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>