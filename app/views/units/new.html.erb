<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm border-0">
        <div class="card-body p-4">

          <h3 class="card-title mb-4 text-center">Add New Unit</h3>

          <%= form_with model: @unit do |form| %>

            <% if @unit.errors.any? %>
              <div class="alert alert-danger">
                <ul class="mb-0">
                  <% @unit.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :property_id, "Property", class: "form-label" %>
                <%= form.collection_select :property_id,
                    @properties,
                    :id,
                    :name,
                    { prompt: "Select a property" },
                    class: "form-select" %>
              </div>

              <div class="col-md-6 mb-3">
                <%= form.label :unit_number, class: "form-label" %>
                <%= form.text_field :unit_number, class: "form-control" %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :size, class: "form-label" %>
                <%= form.number_field :size, class: "form-control" %>
              </div>

              <div class="col-md-6 mb-3">
                <%= form.label :rental_rate, class: "form-label" %>
                <%= form.number_field :rental_rate, class: "form-control" %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :classification, class: "form-label" %>
                <%= form.select :classification,
                    Unit.classifications.keys.map { |k| [k.humanize, k] },
                    { prompt: "Select classification" },
                    class: "form-select" %>
              </div>

              <div class="col-md-6 mb-3">
                <%= form.label :status, class: "form-label" %>
                <%= form.select :status,
                    Unit.statuses.keys.map { |k| [k.humanize, k] },
                    { prompt: "Select status" },
                    class: "form-select" %>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :intended_business_purpose, class: "form-label" %>
              <%= form.text_field :intended_business_purpose, class: "form-control" %>
            </div>

            <div class="mb-4">
              <%= form.label :picture, class: "form-label" %>
              <%= form.text_field :picture, class: "form-control" %>
            </div>

            <div class="d-flex justify-content-end gap-2">
              <%= link_to "Cancel", units_path, class: "btn btn-secondary" %>
              <%= form.submit "Create Unit", class: "btn btn-primary" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>