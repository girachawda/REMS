<h1 class="mb-4">My Appointments</h1>

<% if @appointments.any? %>

  <div class="card shadow-sm">
    <div class="card-body p-0">

      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">

          <thead class="table-light">
            <tr>
              <th>Unit</th>
              <th>Property</th>
              <th>Scheduled Time</th>

              <% if current_user.leasing_agent? %>
                <th>Tenant</th>
              <% else %>
                <th>Agent</th>
              <% end %>

              <th>Status</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% @appointments.each do |appointment| %>
              <tr>

                <td>
                  <strong>Unit <%= appointment.unit.unit_number %></strong>
                </td>

                <td>
                  <%= appointment.unit.property.name %>
                </td>

                <td>
                  <%= appointment.scheduled_at.strftime("%b %d, %Y") %><br>
                  <small class="text-muted">
                    <%= appointment.scheduled_at.strftime("%I:%M %p") %>
                  </small>
                </td>

                <% if current_user.leasing_agent? %>
                  <td><%= appointment.user.name %></td>
                <% else %>
                  <td><%= appointment.availability.user.name %></td>
                <% end %>

                <td>
                  <% case appointment.status %>
                  <% when "pending" %>
                    <span class="badge bg-warning text-dark">Pending</span>
                  <% when "confirmed" %>
                    <span class="badge bg-success">Confirmed</span>
                  <% when "cancelled" %>
                    <span class="badge bg-danger">Cancelled</span>
                  <% when "completed" %>
                    <span class="badge bg-secondary">Completed</span>
                  <% end %>
                </td>

                <td class="text-end">
                  <div class="d-flex justify-content-end gap-2">

                    <% if current_user.leasing_agent? && appointment.pending? %>
                      <%= button_to "Confirm",
                          appointment_path(appointment),
                          method: :patch,
                          params: { status: "confirmed" },
                          class: "btn btn-sm btn-success" %>
                    <% end %>

                    <% if appointment.pending? || appointment.confirmed? %>
                      <%= button_to "Cancel",
                          appointment_path(appointment),
                          method: :patch,
                          params: { status: "cancelled" },
                          class: "btn btn-sm btn-outline-danger" %>
                    <% end %>

                  </div>
                </td>

              </tr>
            <% end %>
          </tbody>

        </table>
      </div>

    </div>
  </div>

<% else %>

  <div class="text-center py-5">
    <h4 class="text-muted mb-3">No appointments yet</h4>
    <%= link_to "Browse Properties",
        properties_path,
        class: "btn btn-primary" %>
  </div>

<% end %>