<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Payments</h1>
    <p class="text-muted mb-0">Track tenant payments and recent transaction history.</p>
  </div>
</div>

<% if @payments.any? %>
  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Tenant</th>
              <th>Amount</th>
              <th>Method</th>
              <th>Paid At</th>
            </tr>
          </thead>

          <tbody>
            <% @payments.each do |payment| %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= payment.account.user.name %></div>
                  <small class="text-muted"><%= payment.account.user.email %></small>
                </td>

                <td class="fw-semibold text-success">
                  $<%= sprintf("%.2f", payment.amount.to_f) %>
                </td>

                <td>
                  <span class="text-capitalize">
                    <%= payment.method.present? ? payment.method.humanize : "—" %>
                  </span>
                </td>

                <td>
                  <% if payment.paid_at.present? %>
                    <div><%= payment.paid_at.strftime("%b %d, %Y") %></div>
                    <small class="text-muted"><%= payment.paid_at.strftime("%I:%M %p") %></small>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% else %>
  <div class="card shadow-sm border-0">
    <div class="card-body text-center py-5">
      <h4 class="text-muted mb-3">No payments found</h4>
      <p class="text-muted mb-0">Recorded payments will appear here.</p>
    </div>
  </div>
<% end %>