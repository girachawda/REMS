<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Account Details</h1>
    <p class="text-muted mb-0">Review account information and outstanding balance.</p>
  </div>

  <%= link_to "Back to Accounts", accounts_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <div class="row mb-3">
      <div class="col-sm-4 text-muted">Tenant</div>
      <div class="col-sm-8">
        <div class="fw-semibold"><%= @account.user.name %></div>
        <small class="text-muted"><%= @account.user.email %></small>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-sm-4 text-muted">Payment Cycle</div>
      <div class="col-sm-8 text-capitalize"><%= @account.payment_cycle %></div>
    </div>

    <div class="row mb-3">
      <div class="col-sm-4 text-muted">Discount</div>
      <div class="col-sm-8"><%= @account.discount_percent.to_f %>%</div>
    </div>

    <div class="row mb-3">
      <div class="col-sm-4 text-muted">Bank Transfer #</div>
      <div class="col-sm-8">
        <%= @account.bank_transfer_number.present? ? @account.bank_transfer_number : "—" %>
      </div>
    </div>

    <div class="row mb-0">
      <div class="col-sm-4 text-muted">Current Balance</div>
      <div class="col-sm-8 fw-semibold">$<%= sprintf("%.2f", @account.balance.to_f) %></div>
    </div>
  </div>
</div>