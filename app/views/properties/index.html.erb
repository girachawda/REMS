<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Property Portfolio</h1>

  <% if current_user&.leasing_agent? %>
    <%= link_to "Add Unit",
        new_unit_path,
        class: "btn btn-primary" %>
  <% end %>
</div>

<div class="card mb-4 shadow-sm">
  <div class="card-body">

    <%= form_with url: properties_path, method: :get, local: true do |form| %>

      <div class="row g-2 align-items-end">

        <div class="col-md-3">
          <%= form.label :location, "Address/City", class: "form-label" %>
          <%= form.text_field :location,
              value: params[:location],
              class: "form-control",
              placeholder: "City or address" %>
        </div>

        <div class="col-md-2">
          <%= form.label :name, "Property", class: "form-label" %>
          <%= form.select :name,
            Property.distinct.order(:name).pluck(:name),
            { include_blank: "All Properties", selected: params[:name] },
            { class: "form-select" } %>
        </div>

        <div class="col-md-2">
          <%= form.label :min_size, "Minimum Size (sq ft)", class: "form-label" %>
          <%= form.number_field :min_size,
              value: params[:min_size].presence || @minimum_size,
              class: "form-control" %>
        </div>

        <div class="col-md-2">
          <%= form.label :max_rate, "Maximum Rent ($)", class: "form-label" %>
          <%= form.number_field :max_rate,
            value: params[:max_rate].presence || @maximum_rent,
            class: "form-control" %>
        </div>

        <div class="col-md-1">
          <%= form.label :classification, class: "form-label" %>
          <%= form.select :classification,
              Unit.classifications.keys.map { |k| [k.humanize, k] },
              { include_blank: "All", selected: params[:classification] },
              { class: "form-select" } %>
        </div>

        <div class="col-md-1">
          <%= form.label :status, class: "form-label" %>
          <%= form.select :status,
              Unit.statuses.keys.map { |k| [k.humanize, k] },
              { include_blank: "All", selected: params[:status] },
              { class: "form-select" } %>
        </div>

        <div class="col-md-1 d-grid">
          <%= form.submit "Search", class: "btn btn-primary" %>
        </div>

      </div>

    <% end %>

  </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">

  <div>
    <%= link_to "Clear Filters",
        properties_path,
        class: "btn btn-outline-secondary btn-sm" %>
  </div>

</div>



<h2>Results (<%= @properties.flat_map(&:units).count %>)</h2>

<div class="row">

  <% @properties.each do |property| %>

    <% property.units.each do |unit| %>

      <div class="col-md-4 mb-4">
        <div class="card property-card shadow-sm h-100">

          <%= image_tag unit.picture,
            class: "card-img-top img-gallery",
            alt: "Property Image" %>

          <div class="card-body">

            <h3 class="card-title">Unit <%= unit.unit_number %> - <%= property.name %></h3>
            <p class="card-text"><strong>Size:</strong> <%= unit.size %> sq ft</p>
            <p class="card-text"><strong>Rental Rate:</strong> $<%= unit.rental_rate %>/month</p>
            <p class="card-text"><strong>Classification:</strong> <%= unit.classification.humanize %></p>
            <p class="card-text"><strong>Status:</strong> <%= unit.status.humanize %></p>

            <p class="card-text">
              <strong>Address:</strong>
              <%= unit.unit_number %> - <%= property.address %>
            </p>

            <p class="card-text">
              <strong>Property Description:</strong>
              <%= property.description %>
            </p>

          </div>

          <div class="card-footer bg-white">

            <% if current_user&.leasing_agent? %>
              
              <%= link_to "Edit Unit",
                  edit_unit_path(unit),
                  class: "btn btn-sm btn-outline-primary" %>

            <% else %>

              <% if unit.available? %>
                <%= link_to "View Details & Schedule",
                  property_unit_path(property, unit),
                  class: "btn btn-sm btn-primary" %>
              <% else %>
                <span class="text-muted">Not Available</span>
              <% end %>

            <% end %>

          </div>

        </div>
      </div>

    <% end %>
    
  <% end %>

</div>